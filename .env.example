# .env.example — 실제 .env로 복사해 값을 채운다 (.env는 커밋 금지).

# 공유 로그인 비밀번호의 bcrypt 해시. (평문 비밀번호는 저장하지 않는다.)
# 생성: npm run hash-pw '원하는비밀번호'   (또는: node src/hash-pw.js '원하는비밀번호')
#   출력된 해시 한 줄을 아래 값에 그대로 붙여넣는다.
# 예: node -e "console.log(require('bcryptjs').hashSync('원하는비밀번호', 10))"
# 미설정 시 로그인은 항상 실패(fail-closed)한다.
APP_PASSWORD_HASH=

# JWT 서명용 시크릿 (충분히 긴 랜덤 문자열).
# 생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
