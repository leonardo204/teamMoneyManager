# .env.example — 실제 .env로 복사해 값을 채운다 (.env는 커밋 금지: .gitignore에 포함).
#   cp .env.example .env

# 초기(부트스트랩) 로그인 비밀번호의 bcrypt 해시. (평문 비밀번호는 저장하지 않는다.)
# 생성: npm run hash-pw '원하는비밀번호'   (또는: node src/hash-pw.js '원하는비밀번호')
#   출력된 해시 한 줄을 아래 값에 그대로 붙여넣는다.
#
# 역할: 이 값은 "최초 기동 시 1회"만 DB(settings.password_hash)로 복사된다.
#   그 이후에는 설정 화면 > 비밀번호 변경으로 바꾸며, 변경분은 DB(볼륨 data/app.db)에 저장된다.
#   즉 한 번 부트스트랩된 뒤에는 이 env를 바꿔도 DB 비밀번호를 덮어쓰지 않는다(설정 변경분 보존).
# 미설정 + DB에도 해시 없음 → 로그인은 항상 실패(fail-closed)한다.
APP_PASSWORD_HASH=

# JWT 서명용 시크릿 (충분히 긴 랜덤 문자열).
# 생성: openssl rand -hex 32
#   (대안: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# (선택) 배포 환경 표시. HTTPS 리버스 프록시(Caddy 등) 뒤에서만 production으로 둔다.
# production이면 세션 쿠키에 secure 플래그가 켜져 HTTP 직결에서는 로그인 쿠키가 전달되지 않는다.
# HTTP(http://VM_IP:49876) 직접 접속이면 비워 두거나 설정하지 않는다.
# NODE_ENV=production
